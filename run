#!/bin/zsh
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_HOST="0.0.0.0"
APP_PORT="8000"
FRONTEND_PORT="${FRONTEND_PORT:-8010}"
PYTHONPATH_VALUE="$ROOT_DIR:$ROOT_DIR/backend"
VENV_PYTHON="$ROOT_DIR/backend/venv/bin/python"
WORKER_PID_FILE="$ROOT_DIR/backend/.local/processing_worker.pid"
WORKER_LOG_FILE="$ROOT_DIR/backend/.local/processing_worker.log"
CAPTURE_SERVICE_ENV_FILE="$ROOT_DIR/backend/.local/capture_service.env"

APP_PID=""
WORKER_PID=""
FRONTEND_PID=""

ensure_runtime_python() {
  if [[ ! -x "$VENV_PYTHON" ]]; then
    echo "Missing runtime Python at $VENV_PYTHON"
    echo "Create the backend virtualenv first, then rerun ./run"
    exit 1
  fi
}

load_capture_service_env() {
  if [[ -f "$CAPTURE_SERVICE_ENV_FILE" ]]; then
    set -a
    source "$CAPTURE_SERVICE_ENV_FILE"
    set +a
  fi
}

cleanup_existing_server() {
  cleanup_port_listener "$APP_PORT" "server"
}

cleanup_port_listener() {
  local port="$1"
  local label="$2"
  local port_pids
  port_pids=("${(@f)$(lsof -tiTCP:${port} -sTCP:LISTEN -n -P 2>/dev/null || true)}")

  if (( ${#port_pids[@]} > 0 )); then
    echo "Stopping existing ${label} on port ${port}: ${port_pids[*]}"
    kill -TERM "${port_pids[@]}" 2>/dev/null || true
    sleep 1

    local remaining_pids
    remaining_pids=("${(@f)$(lsof -tiTCP:${port} -sTCP:LISTEN -n -P 2>/dev/null || true)}")
    if (( ${#remaining_pids[@]} > 0 )); then
      echo "Force stopping lingering ${label} processes: ${remaining_pids[*]}"
      kill -KILL "${remaining_pids[@]}" 2>/dev/null || true
      sleep 1
    fi
  fi
}

detect_display_host() {
  local detected_host
  detected_host="$(python3 - <<'PY'
import socket

host = "127.0.0.1"
try:
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.connect(("8.8.8.8", 80))
    host = sock.getsockname()[0]
    sock.close()
except Exception:
    pass
print(host)
PY
)"
  echo "${detected_host:-127.0.0.1}"
}

cleanup_existing_worker() {
  local pid=""
  if [[ -f "$WORKER_PID_FILE" ]]; then
    pid="$(cat "$WORKER_PID_FILE" 2>/dev/null || true)"
  fi

  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    echo "Stopping existing processing worker: $pid"
    kill -TERM "$pid" 2>/dev/null || true
    sleep 1
  fi

  rm -f "$WORKER_PID_FILE"
}

start_capture_worker() {
  if [[ "${START_CAPTURE_WORKER:-1}" != "1" ]]; then
    echo "Capture worker disabled by START_CAPTURE_WORKER"
    return
  fi

  if [[ -z "${CAPTURE_SERVICE_URL:-}" ]]; then
    echo "Capture worker skipped because CAPTURE_SERVICE_URL is not configured"
    return
  fi

  mkdir -p "$ROOT_DIR/backend/.local"
  cleanup_existing_worker

  echo "Starting capture processing worker for $CAPTURE_SERVICE_URL"
  env PYTHONPATH="$PYTHONPATH_VALUE" "$VENV_PYTHON" "$ROOT_DIR/backend/processing_worker.py" \
    --interval "${CAPTURE_WORKER_INTERVAL:-15}" \
    >>"$WORKER_LOG_FILE" 2>&1 &
  WORKER_PID="$!"
  echo "$WORKER_PID" > "$WORKER_PID_FILE"
}

start_frontend() {
  cleanup_port_listener "$FRONTEND_PORT" "frontend"
  echo "Starting frontend on port ${FRONTEND_PORT}"
  cd "$ROOT_DIR/frontend"
  python3 -m http.server "$FRONTEND_PORT" --bind "0.0.0.0" &
  FRONTEND_PID="$!"
  cd "$ROOT_DIR"
  sleep 1
  if ! kill -0 "$FRONTEND_PID" 2>/dev/null; then
    echo "Frontend failed to start on port ${FRONTEND_PORT}"
    exit 1
  fi
}

cleanup() {
  if [[ -n "$APP_PID" ]] && kill -0 "$APP_PID" 2>/dev/null; then
    kill -TERM "$APP_PID" 2>/dev/null || true
  fi

  if [[ -n "$WORKER_PID" ]] && kill -0 "$WORKER_PID" 2>/dev/null; then
    kill -TERM "$WORKER_PID" 2>/dev/null || true
  fi

  if [[ -n "$FRONTEND_PID" ]] && kill -0 "$FRONTEND_PID" 2>/dev/null; then
    kill -TERM "$FRONTEND_PID" 2>/dev/null || true
  fi

  cleanup_existing_worker
}

cleanup_existing_server
cleanup_existing_worker
load_capture_service_env
ensure_runtime_python

trap cleanup EXIT INT TERM

DISPLAY_HOST="$(detect_display_host)"

if [[ "${RUN_RELOAD:-1}" == "1" ]]; then
  env PYTHONPATH="$PYTHONPATH_VALUE" FRONTEND_PORT="$FRONTEND_PORT" "$VENV_PYTHON" -m uvicorn backend.main:app \
    --host "$APP_HOST" \
    --port "$APP_PORT" \
    --reload \
    --reload-dir "$ROOT_DIR/backend" &
  APP_PID="$!"
  start_capture_worker
  start_frontend
  echo ""
  echo "============================================"
  echo "  Backend:  http://${DISPLAY_HOST}:${APP_PORT}"
  echo "  Frontend: http://${DISPLAY_HOST}:${FRONTEND_PORT}"
  echo "============================================"
  echo ""
  wait "$APP_PID"
  exit $?
fi

env PYTHONPATH="$PYTHONPATH_VALUE" FRONTEND_PORT="$FRONTEND_PORT" "$VENV_PYTHON" -m uvicorn backend.main:app --host "$APP_HOST" --port "$APP_PORT" &
APP_PID="$!"
start_capture_worker
start_frontend
echo ""
echo "============================================"
echo "  Backend:  http://${DISPLAY_HOST}:${APP_PORT}"
echo "  Frontend: http://${DISPLAY_HOST}:${FRONTEND_PORT}"
echo "============================================"
echo ""
wait "$APP_PID"
